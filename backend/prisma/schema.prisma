generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  STAFF

  @@map("user_role")
}

enum EventStatus {
  DRAFT
  PUBLISHED
  FINISHED

  @@map("event_status")
}

enum CertificateDispatchMode {
  MANUAL
  AUTO

  @@map("certificate_dispatch_mode")
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED

  @@map("order_status")
}

enum AttendanceStatus {
  PENDING
  PRESENT
  ABSENT

  @@map("attendance_status")
}

enum CheckInMethod {
  QR
  MANUAL

  @@map("check_in_method")
}

/// Organizador (multi-tenant). Cada tenant tem sua própria conta Asaas.
model Tenant {
  id             String   @id @default(uuid())
  name           String
  subdomain      String   @unique
  asaasAccountId String?  @map("asaas_account_id")
  createdAt      DateTime @default(now()) @map("created_at")

  users  User[]
  events Event[]

  @@map("tenants")
}

/// Usuário com acesso ao painel do organizador. Não faz parte do schema
/// original em docs/ARQUITETURA_credenciamento_eventos.md — adicionado
/// porque login/autenticação precisa de credenciais em algum lugar, e o
/// tenant sozinho representa a organização, não uma pessoa autenticável.
model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(OWNER)
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

model Event {
  id                        String                  @id @default(uuid())
  tenantId                  String                  @map("tenant_id")
  name                      String
  description               String?
  coverImageUrl             String?                 @map("cover_image_url")
  location                  String?
  status                    EventStatus             @default(DRAFT)
  credentialArtworkUrl      String?                 @map("credential_artwork_url")
  credentialNamePosition    Json?                   @map("credential_name_position")
  certificateTemplateUrl    String?                 @map("certificate_template_url")
  certificateNamePosition   Json?                   @map("certificate_name_position")
  certificateDispatchMode   CertificateDispatchMode @default(MANUAL) @map("certificate_dispatch_mode")
  certificateAutoDelayHours Int?                    @map("certificate_auto_delay_hours")
  createdAt                 DateTime                @default(now()) @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eventDays    EventDay[]
  ticketTypes  TicketType[]
  orders       Order[]
  participants Participant[]

  @@index([tenantId])
  @@map("events")
}

/// Define se o evento libera "Lista" (1 dia) ou "QR + fallback manual" (2+ dias).
model EventDay {
  id         String   @id @default(uuid())
  eventId    String   @map("event_id")
  date       DateTime @db.Date
  orderIndex Int      @map("order_index")

  event      Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendance Attendance[]

  @@unique([eventId, orderIndex])
  @@map("event_days")
}

model TicketType {
  id                String    @id @default(uuid())
  eventId           String    @map("event_id")
  name              String
  price             Decimal   @db.Decimal(10, 2)
  quantityAvailable Int       @map("quantity_available")
  saleEndsAt        DateTime? @map("sale_ends_at")

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([eventId])
  @@map("ticket_types")
}

model Order {
  id             String      @id @default(uuid())
  eventId        String      @map("event_id")
  ticketTypeId   String      @map("ticket_type_id")
  buyerName      String      @map("buyer_name")
  buyerEmail     String      @map("buyer_email")
  buyerPhone     String?     @map("buyer_phone")
  asaasPaymentId String?     @map("asaas_payment_id")
  status         OrderStatus @default(PENDING)
  createdAt      DateTime    @default(now()) @map("created_at")

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType  TicketType   @relation(fields: [ticketTypeId], references: [id])
  participant Participant?

  @@index([eventId])
  @@index([ticketTypeId])
  @@map("orders")
}

/// Criado após pagamento aprovado (order.status = PAID).
model Participant {
  id                    String    @id @default(uuid())
  orderId               String    @unique @map("order_id")
  eventId               String    @map("event_id")
  name                  String
  qrToken               String?   @unique @map("qr_token")
  credentialGeneratedAt DateTime? @map("credential_generated_at")
  credentialSentAt      DateTime? @map("credential_sent_at")
  certificateSentAt     DateTime? @map("certificate_sent_at")
  willNotAttend         Boolean   @default(false) @map("will_not_attend")

  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  event      Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendance Attendance[]

  @@index([eventId])
  @@map("participants")
}

/// Agnóstica ao método de check-in: mesma tabela serve "Lista" (1 dia) e
/// "QR + fallback" (2+ dias). UNIQUE(participant, event_day) é o backstop
/// de duplicidade por trás do lock de curta duração no Redis.
model Attendance {
  id            String           @id @default(uuid())
  participantId String           @map("participant_id")
  eventDayId    String           @map("event_day_id")
  status        AttendanceStatus @default(PENDING)
  checkedInAt   DateTime?        @map("checked_in_at")
  method        CheckInMethod?

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  eventDay    EventDay    @relation(fields: [eventDayId], references: [id], onDelete: Cascade)

  @@unique([participantId, eventDayId])
  @@map("attendance")
}
