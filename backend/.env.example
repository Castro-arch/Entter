# PostgreSQL connection string used by Prisma (schema + runtime adapter).
DATABASE_URL="postgresql://entter:entter@localhost:5432/entter?schema=public"

# Secret used to sign organizer session JWTs. Generate with `openssl rand -hex 32`.
JWT_SECRET="replace-with-a-long-random-secret"

# JWT lifetime, also used as the auth cookie's max-age (see auth.controller.ts).
JWT_EXPIRES_IN="7d"

PORT=3000

# Origin of the organizer dashboard, allowed to make credentialed CORS requests.
FRONTEND_URL="http://localhost:3001"

# Secret used to sign attendee QR tokens. Falls back to JWT_SECRET if unset.
QR_SECRET="replace-with-a-long-random-secret"

# Asaas payments. Leave ASAAS_API_KEY empty to run checkout in dev mode (no real
# charge is created; a synthetic payment is returned so the flow still works).
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"
ASAAS_API_KEY=""
# Optional shared secret; when set, the /webhooks/asaas endpoint requires it in
# the `asaas-access-token` header.
ASAAS_WEBHOOK_TOKEN=""
