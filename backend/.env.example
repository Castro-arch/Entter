# PostgreSQL connection string used by Prisma (schema + runtime adapter).
DATABASE_URL="postgresql://entter:entter@localhost:5432/entter?schema=public"

# Secret used to sign organizer session JWTs. Generate with `openssl rand -hex 32`.
JWT_SECRET="replace-with-a-long-random-secret"

# JWT lifetime, also used as the auth cookie's max-age (see auth.controller.ts).
JWT_EXPIRES_IN="7d"

PORT=3000

# Origin of the organizer dashboard, allowed to make credentialed CORS requests.
FRONTEND_URL="http://localhost:3001"
